{
  "name": "@vesty/plugin-ui",
  "version": "0.1.0",
  "description": "Framework-agnostic JavaScript bridge SDK for Vesty WebView plugin editors.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orchiliao/vesty.git",
    "directory": "packages/plugin-ui"
  },
  "homepage": "https://github.com/orchiliao/vesty#readme",
  "keywords": [
    "vst3",
    "audio-plugin",
    "webview",
    "jsbridge",
    "vesty"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "import": "./dist/protocol/index.js"
    },
    "./protocol/*": {
      "types": "./dist/protocol/*.d.ts",
      "import": "./dist/protocol/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node tests/bridge.test.mjs && node tests/protocol-files.test.mjs"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
