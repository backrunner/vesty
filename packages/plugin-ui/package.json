{
  "name": "vesty-plugin-ui",
  "version": "0.1.0",
  "description": "JavaScript bridge SDK and framework adapters for Vesty WebView plugin editors.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/backrunner/vesty.git",
    "directory": "packages/plugin-ui"
  },
  "homepage": "https://github.com/backrunner/vesty#readme",
  "keywords": [
    "vst3",
    "audio-plugin",
    "webview",
    "jsbridge",
    "vesty"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "import": "./dist/protocol/index.js"
    },
    "./protocol/*": {
      "types": "./dist/protocol/*.d.ts",
      "import": "./dist/protocol/*.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    },
    "./svelte": {
      "types": "./dist/svelte.d.ts",
      "import": "./dist/svelte.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node tests/bridge.test.mjs && node tests/protocol-files.test.mjs && node tests/react.test.mjs && node tests/vue.test.mjs && node tests/svelte.test.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "svelte": ">=4",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "latest",
    "react": "latest",
    "svelte": "latest",
    "typescript": "^7.0.2",
    "vue": "latest"
  }
}
