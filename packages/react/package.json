{
  "name": "@vesty/react",
  "version": "0.1.0",
  "description": "React hooks and provider for the Vesty WebView plugin UI bridge.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "repository": {
