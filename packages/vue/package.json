{
  "name": "@vesty/vue",
  "version": "0.1.0",
  "description": "Vue composables for the Vesty WebView plugin UI bridge.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/backrunner/vesty.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/backrunner/vesty#readme",
  "keywords": [
    "vst3",
    "audio-plugin",
    "vue",
    "webview",
    "vesty"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node tests/exports.test.mjs"
  },
  "peerDependencies": {
    "@vesty/plugin-ui": "0.1.0",
    "vue": ">=3"
  },
  "devDependencies": {
    "@vesty/plugin-ui": "0.1.0",
    "typescript": "^7.0.2",
    "vue": "latest"
  }
}
